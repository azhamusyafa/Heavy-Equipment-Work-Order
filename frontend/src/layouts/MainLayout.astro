---
interface Props {
  title: string
}

const { title } = Astro.props
const navItems = [
  { href: '/work-orders', label: 'Work Orders' },
  { href: '/equipment-categories', label: 'Equipment' },
  { href: '/maintenance-types', label: 'Maintenance Types' },
  { href: '/workshop-locations', label: 'Locations' },
]
const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — HeavyWO</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface-900 text-white font-body min-h-screen">

    <div class="noise-overlay"></div>

    <aside class="fixed top-0 left-0 h-full w-60 bg-surface-800 border-r border-white/5 flex flex-col z-50">
      <div class="px-6 py-8">
        <div class="flex items-center gap-3 mb-1">
          <div class="w-8 h-8 rounded-lg bg-accent/20 border border-accent/30 flex items-center justify-center">
            <div class="w-3 h-3 rounded-sm bg-accent"></div>
          </div>
          <span class="font-display font-800 text-lg tracking-tight text-white">HeavyWO</span>
        </div>
        <p class="text-white/30 text-xs font-mono ml-11">Work Order System</p>
      </div>

      <nav class="flex-1 px-3">
        <p class="text-white/20 text-xs font-mono uppercase tracking-widest px-3 mb-3">Navigation</p>
        {navItems.map((item) => {
          const isActive = currentPath.startsWith(item.href)
          return (
            <a
              href={item.href}
              class={`nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 text-sm transition-all duration-200 group ${
                isActive
                  ? 'bg-accent/10 text-accent border border-accent/20'
                  : 'text-white/50 hover:text-white hover:bg-white/5'
              }`}
            >
              <div class={`w-1.5 h-1.5 rounded-full transition-all ${isActive ? 'bg-accent shadow-glow-sm' : 'bg-white/20 group-hover:bg-white/50'}`}></div>
              {item.label}
            </a>
          )
        })}
      </nav>

      <div class="px-6 py-6 border-t border-white/5">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-surface-600 border border-white/10 flex items-center justify-center">
            <span class="text-xs font-mono text-white/50">AD</span>
          </div>
          <div>
            <p class="text-xs text-white/70 font-medium">admin</p>
            <p class="text-xs text-white/30">Basic Auth</p>
          </div>
        </div>
      </div>
    </aside>

    <main class="ml-60 min-h-screen">
      <header class="sticky top-0 z-40 bg-surface-900/80 backdrop-blur-md border-b border-white/5 px-8 py-4 flex items-center justify-between">
        <div>
          <h1 class="font-display font-700 text-xl text-white">{title}</h1>
          <p class="text-white/30 text-xs font-mono mt-0.5">{currentPath}</p>
        </div>
        <div id="global-toast" class="hidden"></div>
      </header>

      <div class="px-8 py-8">
        <slot />
      </div>
    </main>

  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  :root {
    --accent: #6ee7b7;
    --accent-dim: #34d399;
    --surface-900: #0a0a0f;
    --surface-800: #111118;
    --surface-700: #1a1a24;
    --surface-600: #22222f;
  }

  .noise-overlay {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none !important;
    z-index: 1;
    opacity: 0.4;
  }

  ::-webkit-scrollbar {
    width: 4px;
  }

  ::-webkit-scrollbar-track {
    background: var(--surface-800);
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(110,231,183,0.3);
  }

  .glow-text {
    text-shadow: 0 0 20px rgba(110, 231, 183, 0.4);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(110,231,183,0.2); }
    50%       { box-shadow: 0 0 20px rgba(110,231,183,0.5); }
  }

  @keyframes shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.4s ease forwards;
  }

  .skeleton {
    background: linear-gradient(90deg, #1a1a24 25%, #22222f 50%, #1a1a24 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 4px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(110,231,183,0.1);
    border: 1px solid rgba(110,231,183,0.3);
    color: #6ee7b7;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-primary:hover {
    background: rgba(110,231,183,0.2);
    border-color: rgba(110,231,183,0.5);
    box-shadow: 0 0 16px rgba(110,231,183,0.2);
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-danger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.3);
    color: #f87171;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-danger:hover {
    background: rgba(248,113,113,0.2);
    border-color: rgba(248,113,113,0.5);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.5);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.2);
    color: white;
  }

  .card {
    background: #111118;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 24px;
  }

  .input-field {
    width: 100%;
    background: #1a1a24;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 10px 14px;
    color: white;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    outline: none;
  }

  .input-field:focus {
    border-color: rgba(110,231,183,0.4);
    box-shadow: 0 0 0 3px rgba(110,231,183,0.08);
  }

  .input-field::placeholder {
    color: rgba(255,255,255,0.2);
  }

  .input-field.error {
    border-color: rgba(248,113,113,0.5);
    box-shadow: 0 0 0 3px rgba(248,113,113,0.08);
  }

  .input-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .input-error {
    font-size: 12px;
    color: #f87171;
    margin-top: 4px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.03em;
  }

  .badge-open {
    background: rgba(96,165,250,0.1);
    border: 1px solid rgba(96,165,250,0.2);
    color: #60a5fa;
  }

  .badge-inspected {
    background: rgba(251,191,36,0.1);
    border: 1px solid rgba(251,191,36,0.2);
    color: #fbbf24;
  }

  .badge-in-progress {
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.2);
    color: #a78bfa;
  }

  .badge-completed {
    background: rgba(110,231,183,0.1);
    border: 1px solid rgba(110,231,183,0.2);
    color: #6ee7b7;
  }

  .table-row {
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }

  .table-row:hover {
    background: rgba(255,255,255,0.02);
  }

  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }

  .modal-backdrop:not(.hidden) {
    display: flex;
  }

  .modal-box {
    background: #111118;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 32px;
    width: 100%;
    max-width: 520px;
    animation: fadeInUp 0.25s ease forwards;
  }

  .toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 14px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    z-index: 200;
    animation: fadeInUp 0.3s ease forwards;
    max-width: 360px;
  }

  .toast-success {
    background: rgba(110,231,183,0.1);
    border: 1px solid rgba(110,231,183,0.3);
    color: #6ee7b7;
    box-shadow: 0 0 20px rgba(110,231,183,0.1);
  }

  .toast-error {
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.3);
    color: #f87171;
  }
</style>

<script>
  import { globalMessage } from '../lib/store'

  globalMessage.subscribe((msg) => {
    const existing = document.getElementById('global-toast-el')
    if (existing) existing.remove()

    if (!msg) return

    const toast = document.createElement('div')
    toast.id = 'global-toast-el'
    toast.className = `toast ${msg.type === 'success' ? 'toast-success' : 'toast-error'}`
    toast.textContent = msg.text
    document.body.appendChild(toast)

    setTimeout(() => toast.remove(), 4000)
  })
</script>