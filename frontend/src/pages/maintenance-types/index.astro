---
import MainLayout from '../../layouts/MainLayout.astro'
import MaintenanceTypeTable from '../../components/maintenance-types/MaintenanceTypeTable.astro'
import MaintenanceTypeForm from '../../components/maintenance-types/MaintenanceTypeForm.astro'
---

<MainLayout title="Maintenance Types">
  <MaintenanceTypeTable />
  <MaintenanceTypeForm />
</MainLayout>

<script>
  import api from '../../lib/axios'
  import { setGlobalMessage } from '../../lib/store'
  import type { ApiResponse, ApiErrorResponse, MaintenanceType } from '../../types'

  let editingId: number | null = null
  let editingMethod: 'PUT' | 'PATCH' = 'POST' as any

  const modal = document.getElementById('modal-maintenance')!
  const titleEl = document.getElementById('modal-maintenance-title')!
  const skeleton = document.getElementById('maintenance-list-skeleton')!
  const table = document.getElementById('maintenance-table')!
  const tbody = document.getElementById('maintenance-tbody')!
  const empty = document.getElementById('maintenance-empty')!
  const errorEl = document.getElementById('maintenance-error')!

  const inputCode = document.getElementById('input-maintenance-code') as HTMLInputElement
  const inputName = document.getElementById('input-maintenance-name') as HTMLInputElement
  const inputDesc = document.getElementById('input-maintenance-desc') as HTMLTextAreaElement

  function openModal(title: string) {
    titleEl.textContent = title
    modal.classList.remove('hidden')
  }

  function closeModal() {
    modal.classList.add('hidden')
    inputCode.value = ''
    inputName.value = ''
    inputDesc.value = ''
    editingId = null
    clearErrors()
  }

  function clearErrors() {
    ['code', 'name', 'description'].forEach((f) => {
      const el = document.getElementById(`err-${f}`)!
      el.textContent = ''
      el.classList.add('hidden')
    })
  }

  function showErrors(errors: Record<string, string[]>) {
    Object.entries(errors).forEach(([field, msgs]) => {
      const el = document.getElementById(`err-${field}`)
      if (el) { el.textContent = msgs[0]; el.classList.remove('hidden') }
    })
  }

  function setLoading(loading: boolean) {
    const text = document.getElementById('btn-submit-maintenance-text')!
    const loader = document.getElementById('btn-submit-maintenance-loader')!
    const btn = document.getElementById('btn-submit-maintenance') as HTMLButtonElement
    text.classList.toggle('hidden', loading)
    loader.classList.toggle('hidden', !loading)
    btn.disabled = loading
  }

  function renderRows(items: MaintenanceType[]) {
    tbody.innerHTML = items.map((item) => `
      <tr class="table-row">
        <td class="py-3 pr-4 font-mono text-sm text-accent">${item.code}</td>
        <td class="py-3 pr-4 text-sm text-white/80">${item.name}</td>
        <td class="py-3 pr-4 text-sm text-white/40">${item.description ?? '—'}</td>
        <td class="py-3 text-right">
          <button class="btn-ghost text-xs py-1.5 px-3 mr-2 btn-edit-mt"
            data-id="${item.id}"
            data-code="${item.code}"
            data-name="${item.name}"
            data-desc="${item.description ?? ''}"
          >Edit</button>
          <button class="btn-danger text-xs py-1.5 px-3 btn-delete-mt" data-id="${item.id}">Delete</button>
        </td>
      </tr>
    `).join('')

    tbody.querySelectorAll('.btn-edit-mt').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement
        editingId = Number(el.dataset.id)
        editingMethod = 'PATCH'
        inputCode.value = el.dataset.code ?? ''
        inputName.value = el.dataset.name ?? ''
        inputDesc.value = el.dataset.desc ?? ''
        openModal('Edit Maintenance Type')
      })
    })

    tbody.querySelectorAll('.btn-delete-mt').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this type?')) return
        try {
          await api.delete(`/maintenance-types/${(btn as HTMLElement).dataset.id}`)
          setGlobalMessage('success', 'Type deleted.')
          loadTypes()
        } catch {
          setGlobalMessage('error', 'Failed to delete.')
        }
      })
    })
  }

  async function loadTypes() {
    skeleton.classList.remove('hidden')
    table.classList.add('hidden')
    empty.classList.add('hidden')
    errorEl.classList.add('hidden')

    try {
      const res = await api.get<ApiResponse<MaintenanceType[]>>('/maintenance-types')
      const items = res.data.data
      skeleton.classList.add('hidden')
      if (!items.length) { empty.classList.remove('hidden'); return }
      renderRows(items)
      table.classList.remove('hidden')
    } catch {
      skeleton.classList.add('hidden')
      errorEl.textContent = 'Failed to load types.'
      errorEl.classList.remove('hidden')
    }
  }

  document.getElementById('btn-add-maintenance')!.addEventListener('click', () => {
    editingId = null
    openModal('Add Maintenance Type')
  })

  document.getElementById('btn-close-maintenance-modal')!.addEventListener('click', closeModal)
  document.getElementById('btn-cancel-maintenance')!.addEventListener('click', closeModal)
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal() })

  document.getElementById('form-maintenance')!.addEventListener('submit', async (e) => {
    e.preventDefault()
    clearErrors()
    setLoading(true)

    const payload: Record<string, any> = {
      code: inputCode.value,
      name: inputName.value,
      description: inputDesc.value || null,
    }

    try {
      if (editingId) {
        await api.patch(`/maintenance-types/${editingId}`, payload)
        setGlobalMessage('success', 'Type updated.')
      } else {
        await api.post('/maintenance-types', payload)
        setGlobalMessage('success', 'Type created.')
      }
      closeModal()
      loadTypes()
    } catch (err: any) {
      const data: ApiErrorResponse = err.response?.data
      if (data?.errors) showErrors(data.errors)
      else setGlobalMessage('error', data?.message ?? 'Something went wrong.')
    } finally {
      setLoading(false)
    }
  })

  loadTypes()
</script>