---
import MainLayout from '../../layouts/MainLayout.astro'
---

<MainLayout title="Create Work Order">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/work-orders" class="text-white/30 hover:text-white text-sm transition-colors">Work Orders</a>
      <span class="text-white/20">/</span>
      <span class="text-white/60 text-sm">Create</span>
    </div>

    <div class="card animate-fade-in-up">
      <h2 class="font-display font-700 text-lg text-white mb-6">New Work Order</h2>

      <form id="form-create-wo" class="space-y-5" enctype="multipart/form-data">

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="input-label">Maintenance Type <span class="text-accent">*</span></label>
            <select name="maintenance_type_id" id="input-wo-maintenance" class="input-field">
              <option value="">Loading...</option>
            </select>
            <p class="input-error hidden" id="err-maintenance_type_id"></p>
          </div>
          <div>
            <label class="input-label">Equipment Category <span class="text-accent">*</span></label>
            <select name="equipment_category_id" id="input-wo-category" class="input-field">
              <option value="">Loading...</option>
            </select>
            <p class="input-error hidden" id="err-equipment_category_id"></p>
          </div>
        </div>

        <div>
          <label class="input-label">Workshop Location <span class="text-accent">*</span></label>
          <select name="workshop_location_id" id="input-wo-location" class="input-field">
            <option value="">Loading...</option>
          </select>
          <p class="input-error hidden" id="err-workshop_location_id"></p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="input-label">Equipment Serial Number <span class="text-accent">*</span></label>
            <input type="text" name="equipment_serial_number" id="input-wo-serial" class="input-field font-mono" placeholder="e.g. EXC-20T-9981" maxlength="100" />
            <p class="input-error hidden" id="err-equipment_serial_number"></p>
          </div>
          <div>
            <label class="input-label">Current Hour Meter <span class="text-accent">*</span></label>
            <input type="number" name="current_hour_meter" id="input-wo-hourmeter" class="input-field" placeholder="0" min="0" />
            <p class="input-error hidden" id="err-current_hour_meter"></p>
          </div>
        </div>

        <div>
          <label class="input-label">Reporter Name <span class="text-accent">*</span></label>
          <input type="text" name="reporter_name" id="input-wo-reporter" class="input-field" placeholder="Full name" maxlength="150" />
          <p class="input-error hidden" id="err-reporter_name"></p>
        </div>

        <div>
          <label class="input-label">Breakdown Symptom <span class="text-accent">*</span></label>
          <textarea name="breakdown_symptom" id="input-wo-symptom" class="input-field min-h-28 resize-none" placeholder="Describe the problem in detail..."></textarea>
          <p class="input-error hidden" id="err-breakdown_symptom"></p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="input-label">Reported At <span class="text-accent">*</span></label>
            <input type="datetime-local" name="reported_at" id="input-wo-reported" class="input-field" />
            <p class="input-error hidden" id="err-reported_at"></p>
          </div>
          <div>
            <label class="input-label">Machine Down? <span class="text-accent">*</span></label>
            <select name="is_machine_down" id="input-wo-machinedown" class="input-field">
              <option value="false">No</option>
              <option value="true">Yes</option>
            </select>
            <p class="input-error hidden" id="err-is_machine_down"></p>
          </div>
        </div>

        <div>
          <label class="input-label">Damage Photo <span class="text-accent">*</span></label>
          <input type="file" name="damage_photo" id="input-wo-photo" accept=".jpg,.jpeg,.png" class="input-field file:hidden cursor-pointer text-white/30" />
          <p class="text-white/20 text-xs mt-1">JPG or PNG, max 2MB</p>
          <p class="input-error hidden" id="err-damage_photo"></p>
        </div>

        <div class="flex gap-3 pt-4 border-t border-white/5">
          <button type="submit" class="btn-primary flex-1" id="btn-submit-wo">
            <span id="btn-submit-wo-text">Create Work Order</span>
            <span id="btn-submit-wo-loader" class="hidden w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></span>
          </button>
          <a href="/work-orders" class="btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</MainLayout>

<script>
  import api from '../../lib/axios'
  import { setGlobalMessage } from '../../lib/store'
  import type { ApiResponse, ApiErrorResponse, MaintenanceType, EquipmentCategory, WorkshopLocation } from '../../types'

  const form = document.getElementById('form-create-wo') as HTMLFormElement
  const fields = [
    'maintenance_type_id', 'equipment_category_id', 'workshop_location_id',
    'equipment_serial_number', 'current_hour_meter', 'reporter_name',
    'breakdown_symptom', 'reported_at', 'is_machine_down', 'damage_photo',
  ]

  function clearErrors() {
    fields.forEach((f) => {
      const el = document.getElementById(`err-${f}`)
      if (el) { el.textContent = ''; el.classList.add('hidden') }
    })
  }

  function showErrors(errors: Record<string, string[]>) {
    Object.entries(errors).forEach(([field, msgs]) => {
      const el = document.getElementById(`err-${field}`)
      if (el) { el.textContent = msgs[0]; el.classList.remove('hidden') }
    })
  }

  function setLoading(loading: boolean) {
    document.getElementById('btn-submit-wo-text')!.classList.toggle('hidden', loading)
    document.getElementById('btn-submit-wo-loader')!.classList.toggle('hidden', !loading)
    ;(document.getElementById('btn-submit-wo') as HTMLButtonElement).disabled = loading
  }

  async function loadDropdowns() {
    const [mtRes, ecRes, wlRes] = await Promise.all([
      api.get<ApiResponse<MaintenanceType[]>>('/maintenance-types'),
      api.get<ApiResponse<EquipmentCategory[]>>('/equipment-categories'),
      api.get<ApiResponse<WorkshopLocation[]>>('/workshop-locations'),
    ])

    const mtSelect = document.getElementById('input-wo-maintenance') as HTMLSelectElement
    const ecSelect = document.getElementById('input-wo-category') as HTMLSelectElement
    const wlSelect = document.getElementById('input-wo-location') as HTMLSelectElement

    mtSelect.innerHTML = '<option value="">Select type...</option>' +
      mtRes.data.data.map((t) => `<option value="${t.id}">${t.code} — ${t.name}</option>`).join('')

    ecSelect.innerHTML = '<option value="">Select category...</option>' +
      ecRes.data.data.map((c) => `<option value="${c.id}">${c.category_name}</option>`).join('')

    wlSelect.innerHTML = '<option value="">Select location...</option>' +
      wlRes.data.data.map((l) => `<option value="${l.id}">${l.site_code} — ${l.location_name}</option>`).join('')
  }

  const reportedInput = document.getElementById('input-wo-reported') as HTMLInputElement
  reportedInput.value = new Date().toISOString().slice(0, 16)

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    clearErrors()
    setLoading(true)

    const formData = new FormData(form)
    const reportedAt = new Date(formData.get('reported_at') as string).toISOString()
    formData.set('reported_at', reportedAt)

    try {
      await api.post('/work-orders', formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
      })
      setGlobalMessage('success', 'Work order created.')
      window.location.href = '/work-orders'
    } catch (err: any) {
      const data: ApiErrorResponse = err.response?.data
      if (data?.errors) showErrors(data.errors)
      else setGlobalMessage('error', data?.message ?? 'Failed to create work order.')
    } finally {
      setLoading(false)
    }
  })

  loadDropdowns()
</script>