---
interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props
---

<div id={id} class="modal-backdrop hidden" role="dialog">
  <div class="modal-box">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display font-700 text-lg text-white">{title}</h2>
      <button
        class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white/40 hover:text-white hover:bg-white/10 transition-all text-lg leading-none"
        onclick={`document.getElementById('${id}').classList.add('hidden')`}
      >
        &times;
      </button>
    </div>
    <slot />
  </div>
</div>

<script define:vars={{ id }}>
  const backdrop = document.getElementById(id)
  if (backdrop) {
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) {
        backdrop.classList.add('hidden')
      }
    })
  }
</script>