---
---
<div class="card animate-fade-in-up">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="font-display font-700 text-lg text-white">Workshop Locations</h2>
      <p class="text-white/30 text-xs mt-1">Kelola lokasi bengkel</p>
    </div>
    <button class="btn-primary" id="btn-add-location">+ Add Location</button>
  </div>

  <div id="location-list-skeleton" class="space-y-3">
    {Array.from({length: 3}).map(() => (
      <div class="skeleton h-14 w-full"></div>
    ))}
  </div>

  <table class="w-full hidden" id="location-table">
    <thead>
      <tr class="border-b border-white/5">
        <th class="text-left text-xs font-mono text-white/30 uppercase tracking-wider pb-3 pr-4">Site Code</th>
        <th class="text-left text-xs font-mono text-white/30 uppercase tracking-wider pb-3 pr-4">Location</th>
        <th class="text-left text-xs font-mono text-white/30 uppercase tracking-wider pb-3 pr-4">Address</th>
        <th class="text-right text-xs font-mono text-white/30 uppercase tracking-wider pb-3">Actions</th>
      </tr>
    </thead>
    <tbody id="location-tbody"></tbody>
  </table>

  <p id="location-empty" class="hidden text-center text-white/30 text-sm py-12">No locations found.</p>
  <p id="location-error" class="hidden text-center text-danger text-sm py-12"></p>
</div>